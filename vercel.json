{
  "rewrites": [
    {
      "source": "/((?!assets/|sw.js|favicon.ico|manifest.webmanifest|workbox-.*\\.js|pwa-.*\\.png|apple-touch-icon-.*\\.png|maskable-icon-.*\\.png).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}